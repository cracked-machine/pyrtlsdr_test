{
    "tasks": [
        {
            "type": "shell",
            "command": [
                "./scripts/restart_rtl_server.sh"
            ]  ,
            "label": "Restart RTL TCP Server."
        },
        {
            "type": "shell",
            "command": [
                "./scripts/restart_rtl_server.sh && ",
                "./fft/test_python.sh ${input:serverip}"
            ]  ,
            "label": "PythonTest"
        },
        {
            "type": "shell",
            "command": [
                "python3 -m venv venv && ",
                "source venv/bin/activate && ",
                "pip install --upgrade pip -q && ",
                "pip install numpy scipy matplotlib -q && ",
                "python -c \"import numpy, scipy, matplotlib; print('ok', numpy.__version__, scipy.__version__, matplotlib.__version__)\""
            ]  ,
            "label": "PythonSetup"
            
        },
        {
            "type": "shell",
            "command": [
                "./scripts/restart_rtl_server.sh && ",
                "./fft/test_cpp.sh ${input:serverip}"
            ]  ,
            "label": "CppTest"
        },
        {
            "type": "shell",
            "command": [
                "source venv/bin/activate && python3 -c \"import numpy as np; print(np.fromfile('iq.dat', dtype=np.complex64)[:${input:previewsize}])\""
            ],
            "label": "Preview iq.dat"
        
        }
    ],
    "inputs": [
        {
            "id": "serverip",
            "default": "127.0.0.1",
            "type": "promptString",
            "description": "Enter IP address for the server running rtl_tcp"
        },
        {
            "id": "previewsize",
            "default": "20",
            "type": "promptString",
            "description": "Enter size for IQ preview"
        }
    ]
}